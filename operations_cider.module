<?php

/**
 * @file
 * Operations CiDeR module hooks.
 */

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Form\FormStateInterface;

/**
 * Implements hook_node_insert().
 *
 * Send CiDeR resources to all affiliated sites if using the domain_access module.
 */
function operations_cider_node_insert(EntityInterface $entity) {
  $moduleHandler = \Drupal::service('module_handler');
  if ($moduleHandler->moduleExists('domain_access')) {
    $type = $entity->bundle();
    if ($type == 'access_active_resources_from_cid') {
      $entity->field_domain_all_affiliates = TRUE;
      $entity->save();
    }
  }
}

/**
 * Implements hook_form_FORM_ID_alter() for node_access_active_resources_from_cid_edit_form.
 *
 * Makes CiDeR-synced fields readonly so editors can see the data but know to
 * request changes in CiDeR rather than editing here.
 */
function operations_cider_form_node_access_active_resources_from_cid_edit_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  $cider_fields = [
    'body',
    'field_cider_resource_id',
    'field_access_global_resource_id',
    'field_cider_resource_type',
    'field_cider_project_affiliation',
    'field_cider_latest_status',
    'field_cider_latest_status_begin',
    'field_cider_latest_status_end',
    'field_access_org_name',
    'field_access_org_url',
    'field_access_org_logo_url',
    'field_cider_detail_view_url',
    'field_cider_raw_data_url',
  ];

  foreach ($cider_fields as $field_name) {
    if (isset($form[$field_name])) {
      $form[$field_name]['#disabled'] = TRUE;
      $form[$field_name]['#prefix'] = ($form[$field_name]['#prefix'] ?? '') . '<div class="cider-synced-field">';
      $form[$field_name]['#suffix'] = '</div>' . ($form[$field_name]['#suffix'] ?? '');
    }
  }

  // Add a note above the CiDeR section.
  $form['cider_section_notice'] = [
    '#type' => 'markup',
    '#markup' => '<div class="messages messages--warning"><strong>CiDeR-synced fields</strong> — The fields below are automatically synced from CiDeR. To change this data, update it in CiDeR and it will sync here on the next import.</div>',
    '#weight' => 49,
  ];
}

/**
 * Implements hook_entity_create().
 */
function operations_cider_entity_presave(EntityInterface $entity) {
  $moduleHandler = \Drupal::service('module_handler');
  if ($entity->getEntityTypeId() == 'node' && $moduleHandler->moduleExists('domain_access')) {
    $type = $entity->bundle();
    if ($type == 'access_active_resources_from_cid') {
      // Only run on new entities.
      if ($entity->id() == NULL) {
        $field_domain_access = $entity->get('field_domain_access')->getValue();
        // Set default domain when null is passed.
        if (empty($field_domain_access)) {
          $entity->set('field_domain_access', 'amp_cyberinfrastructure_org');
        }
      }
    }
  }
}
